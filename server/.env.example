PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/mediq
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173

# ─── LLM Provider Configuration ───────────────────────────────────────────────
# Set ONE of the following to enable AI-powered triage.
# If none are set, the system falls back to rule-based logic automatically.

# Provider selector (optional — auto-detected if not set)
# Values: openai | gemini | ollama
# LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# ── Ollama (local) ────────────────────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
